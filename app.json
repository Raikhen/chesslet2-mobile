{
  "expo": {
    "name": "Chesslet",
    "slug": "chesslet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "chesslet",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f0d9b5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.raikhen.chesslet",
      "buildNumber": "1",
      "icon": "./assets/ios-icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f0d9b5"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.raikhen.chesslet"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a6118cd8-b9c5-4e16-ae95-8278e3852a35"
      }
    },
    "owner": "raikhen"
  }
}
